APP_ENV=development
APP_NAME=NTEXECG
APP_VERSION=1.0.0

# Local PostgreSQL (NTDEV — no Docker)
DATABASE_URL=postgresql+asyncpg://ntexecg:password_dev@localhost:5432/ntexecg
POSTGRES_USER=ntexecg
POSTGRES_PASSWORD=password_dev
POSTGRES_DB=ntexecg

SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
WEBHOOK_TOKEN_SALT=dev_salt_change_in_production_min_32_chars
LUXALGO_WEBHOOK_SECRET=dev_global_token

# Web UI auth (single admin user)
UI_USERNAME=admin
# bcrypt hash of the admin password. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
UI_PASSWORD=
# HS256 session signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

TRADERSPOST_ENABLED=false
DRY_RUN=true

DEFAULT_TIMEZONE=America/New_York
LOG_LEVEL=DEBUG

MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=1

# NTDEV uses yfinance (no NTRADER bridge via VPN)
MARKET_DATA_PROVIDER=yfinance
NTBRIDGE_PATH=/mnt/ntbridge
NTBRIDGE_HEARTBEAT_MAX_AGE=60
MARKET_DATA_FALLBACK_ENABLED=false

NEWS_CACHE_TTL_MINUTES=60
