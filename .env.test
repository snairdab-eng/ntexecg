# Deterministic test environment — loaded ONLY when APP_ENV=test (see
# app/core/config.py and tests/conftest.py). Contains NO secrets: every value
# is a public dev default so the suite passes identically on any host and never
# depends on the production .env.
APP_ENV=test
DATABASE_URL=sqlite+aiosqlite:///:memory:
LUXALGO_WEBHOOK_SECRET=dev_global_token
WEBHOOK_TOKEN_SALT=dev_salt_change_in_production_min_32_chars
DRY_RUN=true
TRADERSPOST_ENABLED=false
MARKET_DATA_PROVIDER=yfinance
